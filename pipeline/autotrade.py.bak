# DAO分析师 V3.3 — 3万核心作战系统
#!/usr/bin/env python3
"""自动交易 — 600元风险公式 + 分阶止盈 + MA5跟踪"""
import sys, os, json, urllib.request, ssl
from datetime import datetime

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
BASE = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
WATCHLIST = os.path.join(BASE, "data", "watchlist.json")
DAILY_STATE = os.path.join(BASE, "data", "state", "band.json")
ssl._create_default_https_context = ssl._create_unverified_context

MAX_STOCKS_PER_DAY = 3  # default

def get_max_stocks():
    try:
        from market_thermometer_v2 import get_thermometer
        t = get_thermometer()
        if '进攻占优' in str(t.get('level','')):
            return 5
        if '防御抬头' in str(t.get('level','')):
            return 2
    except:
        pass
    return MAX_STOCKS_PER_DAY
CORE_CAP = 6000       # 核心作战仓(波段→MX妙想)
GUERRILLA_CAP = 10000  # 机动游击仓(预留)
TOTAL_CAP = 6000      # 总资金=核心仓(已统一)
MAX_LOSS = 600  # default, overridden by evolve if set         # 单笔最大亏损

def _get_band_trader():
    """获取波段专用交易通道(MX妙想)"""
    from trader import UnifiedTrader
    return UnifiedTrader(strategy="band")



EVOLVE_PARAMS_FILE = os.path.join(BASE, "data", "evolve_params.json")

def load_evolve_params():
    """加载进化参数，失败则返回默认值"""
    try:
        if os.path.exists(EVOLVE_PARAMS_FILE):
            ep = json.load(open(EVOLVE_PARAMS_FILE))
            return ep.get("band", {})
    except: pass
    return {}

def get_param(key, default):
    """获取参数：优先进化值→默认值"""
    bp = load_evolve_params()
    return bp.get(key, default)

def get_band_positions():
    """获取波段持仓(通过UnifiedTrader→MX)"""
    trader = _get_band_trader()
    resp = trader.positions()
    data = resp.get("data", resp)
    pl = data.get("posList", [])
    pos, tv, tp = {}, 0, 0
    for p in pl:
        code = p.get("secCode", p.get("code",""))
        qty = p.get("count", p.get("qty",0))
        cost = p.get("costPrice", 0)
        if isinstance(cost, (int, float)) and cost > 10000:
            cost = cost / (10**p.get("costPriceDec", 3))
        value = p.get("value", 0) / 1000 if p.get("value", 0) > 10000 else p.get("value", 0)
        profit = p.get("profit", 0) / 1000 if abs(p.get("profit", 0)) > 10000 else p.get("profit", 0)
        tv += value; tp += profit
        pos[code] = {"name": p.get("secName", p.get("name","")), "qty": qty, "cost": cost, "value": value,
                     "profit": profit, "profit_pct": p.get("profitPct", p.get("profit_pct",0))}
    return pos, tv, tp


def load_daily_state():
    today = datetime.now().strftime("%Y-%m-%d")
    if os.path.exists(DAILY_STATE):
        s = json.load(open(DAILY_STATE))
        if s.get("date") == today: return s
    return {"date": today, "stocks": [], "total_spent": 0, "buy_count": 0}


def save_daily_state(s):
    os.makedirs(os.path.dirname(DAILY_STATE), exist_ok=True)
    with open(DAILY_STATE, "w") as f:
        json.dump(s, f, ensure_ascii=False, indent=2)


def calc_shares(entry_price, stop_price, risk_limit=None):
    """仓位公式: 趋势600/震荡400/熊市0"""
    regime = get_market_regime()
    if regime == "BEAR": return 0  # 熊市不交易
    if risk_limit is None:
        bp = load_evolve_params()
        risk_limit = int(TOTAL_CAP * bp.get("position_risk_pct", 0.02))
    risk = risk_limit if regime == "TREND" else int(risk_limit * 0.67)  # 震荡降低风险
    if entry_price <= stop_price: return 0
    shares = int(risk / (entry_price - stop_price) / 100) * 100
    if shares < 100: return 0
    value = shares * entry_price
    if value > CORE_CAP: shares = int(CORE_CAP / entry_price / 100) * 100
    if shares * entry_price < 1500: return 0
    return shares


def _exec_trade(action, code, name, price, qty, dry_run=True):
    """执行交易(通过UnifiedTrader→MX妙想波段通道)"""
    value = price * qty
    if dry_run:
        return True, f"📋 {action} {name}({code}) {qty}股 @¥{price:.2f} = ¥{value:,.0f}"
    
    # 下单前写预通知
    pre_alert = {
        "time": datetime.now().strftime('%H:%M:%S'),
        "action": f"PRE_{action}",
        "code": code, "name": name,
        "price": price, "quantity": qty,
        "value": value,
        "message": f"📋准备{'买入' if action=='BUY' else '卖出'}: {name}({code}) {qty}股 @¥{price:.2f} = ¥{value:,.0f}"
    }
    try:
        alerts = []
        alert_file = '/tmp/dao_trade_alerts.json'
        if os.path.exists(alert_file):
            alerts = json.load(open(alert_file))
        alerts.append(pre_alert)
        with open(alert_file, "w") as f:
            json.dump(alerts, f, ensure_ascii=False)
    except: pass
    
    trader = _get_band_trader()
    if action == "BUY":
        resp = trader.buy(code, price, qty)
    else:
        resp = trader.sell(code, price, qty)
    ok = resp.get("ok", False) or resp.get("code") == "200"
    from pipeline.trade_notify import notify_trade
    notify_trade(action, code, name, price, qty, "成功" if ok else resp.get("message","失败"))
    return ok, f"{'✅' if ok else '❌'} {action} {name}({code}) {qty}股 @¥{price:.2f} = ¥{value:,.0f}"


def get_stop_stages(entry, stop, current):
    """分阶止盈: 趋势慢卖/震荡快卖"""
    regime = get_market_regime()
    profit_pct = (current / entry - 1) * 100
    
    if regime == "TREND":
        # 趋势: 让利润奔跑
        bp = load_evolve_params()
        tp3 = bp.get("tp_clear_pct", 0.15) * 100
        tp2 = bp.get("tp_half_pct", 0.08) * 100
        tp1 = bp.get("tp_protect_pct", 0.02) * 100
        if profit_pct >= tp3: return "MA5跟踪", f"趋势强,收盘破MA5清仓"
        elif profit_pct >= tp2: return "卖半仓", f"卖50% 剩余保本"
        elif profit_pct >= tp1: return "保本上移", f"止损→¥{entry:.2f}"
    elif regime == "CHOP":
        # 震荡: 快进快出
        bp = load_evolve_params()
        cp2 = bp.get("tp_half_pct", 0.08) * 100
        cp1 = bp.get("tp_protect_pct", 0.02) * 100
        if profit_pct >= cp2: return "清仓", f"震荡市不贪,落袋+{profit_pct:.0f}%"
        elif profit_pct >= cp1 * 1.5: return "卖半仓", f"卖50%锁利"
        elif profit_pct >= cp1 * 0.5: return "保本上移", f"止损→¥{entry:.2f}"
    else:
        # 熊市不交易
        return "不交易", "熊市"
    
    return "持有", f"止损¥{stop:.2f}"


def get_market_regime():
    """市场状态判断: TREND=趋势, CHOP=震荡, BEAR=熊市"""
    try:
        from market_sentiment import get_market_sentiment
        s, _ = get_market_sentiment()
        if s == "🟢积极": return "TREND"
        elif s == "🟡中性": return "CHOP"
        elif s == "🔴谨慎": return "BEAR"
    except Exception as e:
        pass
    return "CHOP"  # 默认震荡(保守)


def _get_market_regime():
    """获取市场状态 + 风格偏好"""
    import urllib.request
    try:
        raw = urllib.request.urlopen(
            'https://qt.gtimg.cn/q=sh000001,sz399001,sz399006', timeout=5
        ).read().decode('gbk')
        chgs = []
        for ln in raw.strip().splitlines():
            d = ln.split('~')
            if len(d) >= 33: chgs.append(float(d[32]))
        avg = sum(chgs) / len(chgs) if chgs else 0
    except:
        avg = 0
    
    if avg > 1.5: return {'regime': 'BULL', 'label': '🟢进攻市', 'style': '成长+周期',
                          'prefer': ['电子','制造','新能源','科技','信息'],
                          'avoid': ['银行','公用','防御']}
    elif avg > 0.3: return {'regime': 'NEUTRAL_BULL', 'label': '🟢偏进攻', 'style': '均衡偏成长',
                            'prefer': ['电子','制造','消费','新能源'],
                            'avoid': []}
    elif avg > -0.3: return {'regime': 'NEUTRAL', 'label': '🟡震荡市', 'style': '均衡',
                             'prefer': [], 'avoid': []}
    elif avg > -1.5: return {'regime': 'NEUTRAL_BEAR', 'label': '🟠偏防御', 'style': '均衡偏防御',
                             'prefer': ['能源','电力','银行','公用'],
                             'avoid': ['电子','科技','高PE']}
    else: return {'regime': 'BEAR', 'label': '🔴防御市', 'style': '纯防御',
                  'prefer': ['银行','高股息','公用','电力'],
                  'avoid': ['电子','科技','制造','新能源','高PE']}

def _rank_band_stocks(band, market):
    """市场感知排序：优先抢市场匹配的标的"""
    # 简单板块关键词
    sec_map = {
        '银行': ['银行'], '能源': ['能源','煤炭','电力','发电','燃气'],
        '电子': ['电子','电路','pcb','元件','半导体','芯片','光电'],
        '制造': ['机械','制造','设备','重工','精密'],
        '消费': ['食品','饮料','酒','零售','服装','消费'],
        '信息': ['软件','计算机','数据','通信','ai','智能','信息'],
        '医药': ['医药','药','生物','医疗'],
        '公用': ['港口','机场','高速','运输','物流','环保','水务'],
        '周期': ['化工','化学','材料','有色','钢铁','矿','稀土'],
        '其他': []
    }
    
    def _get_sec(name):
        for sec, kws in sec_map.items():
            if any(kw in name for kw in kws): return sec
        return '其他'
    
    ranked = []
    for s in band:
        name = s.get('name', '')
        sec = _get_sec(name)
        sc = 0
        
        # 市场打赏：偏好板块加分
        if any(pref.lower() in sec.lower() for pref in market['prefer']):
            sc += 30
        # 避开板块减分
        if any(av.lower() in sec.lower() for av in market['avoid']):
            sc -= 20
        
        # 池内优先级
        note = s.get('note', '')
        if '龙头' in note: sc += 10
        if '涨停' in note: sc += 5
        
        ranked.append((sc, s))
    
    ranked.sort(key=lambda x: -x[0])
    return [s for _, s in ranked]


def auto_trade(dry_run=True):
    from pipeline.fetcher import fetch
    from pipeline.signals import analyze
    from pipeline.idempotent_guard import check_idempotent, verify_mx_position, release_lock
    from pipeline.freeze_guard import check_consecutive_losses, is_strategy_frozen, freeze_strategy, check_time_stop, record_daily_pnl
    
    wl = json.load(open(WATCHLIST))
    band = wl.get("groups", {}).get("band", {}).get("stocks", [])
    state = load_daily_state()
    
    mx_pos, mx_tv, mx_tp = {}, 0, 0
    dyn_cap = CORE_CAP
    if not dry_run:
        try: mx_pos, mx_tv, mx_tp = get_band_positions(); dyn_cap = CORE_CAP + mx_tp
        except: pass
    
    used = mx_tv if mx_tv > state["total_spent"] else state["total_spent"]
    remaining = dyn_cap - used if not dry_run else dyn_cap - state["total_spent"]
    
    lines = [f"🤖 3万作战系统 {'[模拟]' if dry_run else '[实盘]'}"]
    lines.append(f"  核心仓¥{CORE_CAP:,} | 单笔风险¥600 | 分阶止盈")
    lines.append(f"  今日 {state['buy_count']}/{get_max_stocks()}只 | 剩余¥{remaining:,.0f}")
    lines.append("")
    
    executed = []
    bought = {st["code"] for st in state["stocks"]}
    
    # ═══ 市场感知：波段池重排序 ═══
    market = _get_market_regime()
    regime = get_market_regime()
    # CHOP震荡市: 收紧ATR止损乘数 2.0→1.2
    atr_mult = 1.2 if regime == "CHOP" else 2.0
    band = _rank_band_stocks(band, market)
    lines.append(f"  📊 市场: {market['label']} | 风格: {market['style']}")
    lines.append("")
    
    # 🛡️ 策略冻结检查
    frozen, freeze_reason = is_strategy_frozen()
    if frozen:
        lines.append(f"  🧊 策略冻结: {freeze_reason}")
        lines.append(f"  ⛔ 今日暂停所有买入")
        sell_only = True  # 只允许卖出
    else:
        # 连亏检查(买入前)
        has_losses, n_loss, loss_reason = check_consecutive_losses()
        if has_losses:
            until = freeze_strategy(loss_reason)
            lines.append(f"  🔴 {loss_reason}")
            lines.append(f"  🧊 策略冻结至 {until}")
            sell_only = True  # 只允许卖出
        else:
            sell_only = False
    
    # 14:30后只卖不买 (T+1安全)
    now = datetime.now()
    if not sell_only:
        sell_only = now.hour >= 14 and now.minute >= 30
    
    for s in band:
        code = s["code"]; name = s["name"]
        
        if sell_only:
            lines.append(f"  🔒 尾盘模式 — 跳过买入,仅执行卖出")
            break
        if state["buy_count"] >= get_max_stocks():
            lines.append(f"  ⏭️ {name} (今日{get_max_stocks()}只满)"); continue
        if code in bought:
            lines.append(f"  ⏭️ {name} (今日已买)"); continue
        if not dry_run and code in mx_pos:
            lines.append(f"  ⏭️ {name} (已持{mx_pos[code]['qty']}股)"); continue
        
        d = fetch(code, use_cache=True)
        if "error" in d: lines.append(f"  ❌ {name} 数据错误"); continue
        
        a = analyze(d, atr_mult); sig = a["g"]; score = a.get("score", sig * 16); chg = d["chg"]; price = d["price"]; pr = a["prices"]
        
        # 市场自适应阈值
        threshold = {'BULL': 40, 'NEUTRAL_BULL': 45, 'NEUTRAL': 50, 'NEUTRAL_BEAR': 55, 'BEAR': 60}
        min_score = threshold.get(market['regime'], 50) if market else 50
        if score < min_score:
            lines.append(f"  ⏭️ {name} (评分{score}<{min_score})"); continue
        
        # 涨跌停保护
        prev_close = d.get("pre_close", price)
        limit_up = round(prev_close * 1.10, 2)
        limit_down = round(prev_close * 0.90, 2)
        if price >= limit_up:
            lines.append(f"  ⏭️ {name} (已涨停不再追)"); continue
        if price <= limit_down:
            lines.append(f"  ⏭️ {name} (跌停不抄底)"); continue
        if chg >= 5: lines.append(f"  ⏭️ {name} (涨幅{chg:+.1f}%追高)"); continue
        if chg <= -2: lines.append(f"  ⏭️ {name} (跌幅{chg:+.1f}%)"); continue
        
        # 量比门槛: 无量不交易
        vol_ratio = d.get('vol_ratio', 1.0)
        if vol_ratio < 0.3:
            lines.append(f"  ⏭️ {name} (量比{vol_ratio:.1f}x地量)"); continue
        
        # 日内位置: 不在日内高位追买
        day_high, day_low = d.get('high', price), d.get('low', price)
        day_open = d.get('open', prev_close)
        if day_high > day_low:
            range_pos = (price - day_low) / (day_high - day_low)
            if range_pos > 0.85:
                lines.append(f"  ⏭️ {name} (日内高位{range_pos:.0%})"); continue
            if range_pos < 0.15 and chg < 0:
                lines.append(f"  ⏭️ {name} (日内低位+下跌,等企稳)"); continue
        
        min_cost = price * 100
        if remaining < min_cost:
            lines.append(f"  ⏭️ {name} (剩余¥{remaining:,.0f}不够1手)"); continue
        
        # 评分分档: 高信心多买,低信心少买
        # 市场温度动态调节阈值
        temp_mult = 1.0
        try:
            from market_thermometer_v2 import get_thermometer
            t = get_thermometer()
            level = t.get('level', '')
            if '进攻占优' in level: temp_mult = 0.85    # 进攻市放大仓位
            elif '防御抬头' in level: temp_mult = 0.6   # 防御抬头减仓
            elif '防御主导' in level: temp_mult = 0      # 防御主导暂停
        except: pass
        
        if score >= 70:
            risk_limit = int(600 * temp_mult)
        elif score >= 55:
            risk_limit = int(450 * temp_mult)
        elif score >= 40:
            risk_limit = int(300 * temp_mult)
        else:
            risk_limit = 0  # score<40不交易
        
        # ── 估值安全边际检查(仅波段) ──
        try:
            from pipeline.valuation import valuation_filter
            val_ok, val_reason = valuation_filter(code)
            if not val_ok:
                print(f"  ⏭️ {name}({code}) {val_reason} → 跳过")
                continue
            if score < 70:  # 估值好可加分
                score = min(100, score + 5)
                print(f"  📊 {name}({code}) 估值支撑 +5分")
        except Exception as e:
            pass  # 估值模块不可用时放行
        
        # ── 行业集中度检查 ──
        try:
            from pipeline.risk_controls import check_sector_concentration, get_sector
            sec = get_sector(code)
            ok, conc, warn = check_sector_concentration(positions, code, sec)
            if not ok:
                print(f"  ⛔ {name}({code}) {warn} → 跳过")
                continue
        except Exception as e:
            pass  # 风控模块不可用时放行
        
        shares = calc_shares(price, pr["stop_loss"], risk_limit)
        if shares < 100:
            lines.append(f"  ⏭️ {name} (止损空间过大,放弃)"); continue
        
        # 🔒 幂等锁: 同代码同方向300s内禁止重复
        allowed, lock_reason = check_idempotent(code, "BUY", dry_run)
        if not allowed:
            lines.append(f"  🔒 {name} {lock_reason}"); continue
        
        value = shares * price
        risk = shares * (price - pr["stop_loss"])
        
        ok, msg = _exec_trade("BUY", code, name, price, shares, dry_run)
        if not ok:
            release_lock(code, "BUY")
        lines.append(f"  {msg} {score:.0f}分 风险¥{risk:,.0f}")
        lines.append(f"     止损¥{pr['stop_loss']:.2f} 止盈¥{pr['take_profit_1']:.2f}")
        
        # 分阶计划
        stage, action = get_stop_stages(price, pr["stop_loss"], price)
        bp2 = load_evolve_params()
        tp1p = bp2.get("tp_protect_pct", 0.02) * 100
        tp2p = bp2.get("tp_half_pct", 0.08) * 100
        tp3p = bp2.get("tp_clear_pct", 0.15) * 100
        lines.append(f"     +{tp1p:.0f}%→保本 +{tp2p:.0f}%→卖半 +{tp3p:.0f}%→MA5跟踪")
        
        if ok:
            executed.append({"code": code, "name": name, "shares": shares, "price": price, "value": value})
            state["stocks"].append({"code": code, "name": name, "shares": shares, "price": price, "value": value, "entry_date": state["date"]})
            state["buy_count"] += 1; state["total_spent"] += value
            bought.add(code); remaining -= value
    

    # T+1检查: 当天买的不能卖
    today_codes = {st["code"] for st in state["stocks"]}

    # ═══ CHOP时间止损检查 (震荡市: 持仓>3天未盈利→强制平仓) ═══
    regime = get_market_regime()
    if regime == "CHOP" and not dry_run and mx_pos:
        # 从daily_state获取买入日期
        entry_dates = {}
        for st in state.get("stocks", []):
            entry_dates[st["code"]] = st.get("entry_date", state.get("date", ""))
        
        time_stops = check_time_stop(mx_pos, entry_dates, dry_run)
        for code, reason in time_stops:
            if code in mx_pos and code not in today_codes:
                pos = mx_pos[code]
                d = fetch(code, use_cache=True)
                if "error" in d: continue
                price = d["price"]
                ok, msg = _exec_trade("SELL", code, pos["name"], price, pos["qty"], dry_run)
                lines.append(f"  ⏰ {msg} ({reason})")
                if ok:
                    remaining += pos["qty"] * price
                    record_daily_pnl(pnl=pos.get("profit", 0) / 1000)

    # 止盈止损检查
    if not dry_run and mx_pos:
        for code, pos in mx_pos.items():
            if code in today_codes:
                lines.append(f"  🔒 {pos['name']} T+1锁仓(今日买入)")
                continue
            
            # 🔒 幂等卖出: 校验持仓真实存在
            exists, actual_qty, verify_reason = verify_mx_position(code, mx_pos, "SELL")
            if not exists:
                lines.append(f"  ⛔ {pos['name']} {verify_reason}")
                continue
            
            d = fetch(code, use_cache=True)
            if "error" in d: continue
            a = analyze(d, atr_mult); price = d["price"]; pr = a["prices"]
            profit_pct = pos["profit_pct"]
            
            should = False; reason = ""
            entry = pos["cost"]
            
            bp = load_evolve_params()
            sl = bp.get("stop_loss_pct", -0.06) * 100
            tp_clear = bp.get("tp_clear_pct", 0.15) * 100
            tp_half = bp.get("tp_half_pct", 0.08) * 100
            tp_protect = bp.get("tp_protect_pct", 0.02) * 100
            if profit_pct <= sl: should = True; reason = f"止损{profit_pct:.0f}%"
            elif profit_pct >= tp_clear: should = True; reason = f"大赚{profit_pct:.0f}%清仓"
            elif profit_pct >= tp_half: should = True; reason = f"小赚{profit_pct:.0f}%卖半仓"
            elif profit_pct >= 1:
                # 上移止损到成本价
                reason = f"微赚{profit_pct:.0f}%→保本"
                # No sell, just log
                lines.append(f"  🟢 {pos['name']} {reason}")
            
            if should and "卖半仓" in reason:
                sell_qty = max(100, pos["qty"] // 2 // 100 * 100)
                # 🔒 幂等检查
                allowed, lock_reason = check_idempotent(code, "SELL", dry_run)
                if not allowed:
                    lines.append(f"  🔒 {pos['name']} {lock_reason}"); continue
                ok, msg = _exec_trade("SELL", code, pos["name"], price, sell_qty, dry_run)
                lines.append(f"  {msg} ({reason})")
                if ok:
                    remaining += sell_qty * price
                    record_daily_pnl(pnl=pos.get("profit", 0) / 1000)
                else:
                    release_lock(code, "SELL")
            elif should:
                # 🔒 幂等检查
                allowed, lock_reason = check_idempotent(code, "SELL", dry_run)
                if not allowed:
                    lines.append(f"  🔒 {pos['name']} {lock_reason}"); continue
                ok, msg = _exec_trade("SELL", code, pos["name"], price, pos["qty"], dry_run)
                lines.append(f"  {msg} ({reason})")
                if ok:
                    remaining += pos["qty"] * price
                    record_daily_pnl(pnl=pos.get("profit", 0) / 1000)
                else:
                    release_lock(code, "SELL")
    
    save_daily_state(state)
    if executed:
        lines.append(f"\n💰 今日买入 {len(executed)}只 ¥{sum(e['value'] for e in executed):,.0f}")
    else:
        lines.append(f"\n💰 今日无买入")
    return "\n".join(lines), executed


if __name__ == "__main__":
    if "--plan" in sys.argv:
        # 计划模式: 生成交易计划,写入文件
        dry = "--real" not in sys.argv
        result, executed = auto_trade(dry_run=dry)
        print(result)
        plan_file = '/tmp/dao_band_plan.json'
        plan = {
            "time": datetime.now().strftime('%Y-%m-%d %H:%M:%S'),
            "executed": False,
            "trades": executed
        }
        with open(plan_file, "w") as f:
            json.dump(plan, f, ensure_ascii=False)
        print(f'\n📋 交易计划已写入 {plan_file}: {len(executed)}笔')
    elif "--execute" in sys.argv:
        # 执行模式: 读取计划,逐笔执行
        plan_file = '/tmp/dao_band_plan.json'
        if not os.path.exists(plan_file):
            print('⏭ 无交易计划文件')
            sys.exit(0)
        plan = json.load(open(plan_file))
        plan['executed'] = True
        with open(plan_file, "w") as f:
            json.dump(plan, f, ensure_ascii=False)
        
        trades = plan.get('trades', [])
        print(f'📋 执行{len(trades)}笔交易')
        for t in trades:
            action = t.get('action','BUY')
            code = t['code']; name = t['name']
            price = t['price']; qty = t.get('quantity', t.get('shares', 0))
            ok, msg = _exec_trade(action, code, name, price, qty, dry_run=False)
            print(f'  {msg}')
        print('✅ 计划执行完成')
    else:
        dry = "--real" not in sys.argv
        result, _ = auto_trade(dry_run=dry)
        print(result)

